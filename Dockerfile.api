FROM node:20-slim

RUN apt-get update && apt-get install -y git python3 make g++ build-essential && rm -rf /var/lib/apt/lists/*

# Pin pnpm to v9 — compatible with lockfileVersion '9.0'
RUN npm config set strict-ssl false && npm install -g pnpm@9

WORKDIR /workspace

COPY . .

RUN pnpm install --frozen-lockfile --ignore-scripts

# Rebuild native modules for the container platform
RUN pnpm rebuild

EXPOSE 8080

CMD ["pnpm", "--filter", "@workspace/api-server", "run", "dev"]

